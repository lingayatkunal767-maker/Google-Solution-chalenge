# VolunteerMatch AI - Backend Environment Variables
# Copy this file to .env and fill in your values

# Firebase Project
FIREBASE_PROJECT_ID=volunteermatch-ai
FIREBASE_STORAGE_BUCKET=volunteermatch-ai.appspot.com

# Service Account (paste your JSON as a single line, or use ADC in production)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":...}

# Server
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002

# Firestore Emulator (development only)
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
